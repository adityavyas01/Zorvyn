{
  "info": {
    "_postman_id": "8e64a2f5-6053-4a6d-a687-98a84bb8f4aa",
    "name": "Zorvyn API",
    "description": "Postman collection for Zorvyn auth, records, and stats APIs with token automation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth APIs",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman {{$randomFirstName}}\",\n  \"email\": \"postman.{{$timestamp}}@example.com\",\n  \"password\": \"Passw0rd!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/register",
            "description": "Creates a new user account."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Register returns success envelope', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('success');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as Analyst (set token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{analystEmail}}\",\n  \"password\": \"{{analystPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Logs in as Analyst and saves JWT to collection variable token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login successful', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "if (body && body.data && body.data.token) {",
                  "  pm.collectionVariables.set('token', body.data.token);",
                  "}",
                  "if (body && body.data && body.data.user) {",
                  "  pm.collectionVariables.set('userId', body.data.user.id || '');",
                  "  pm.collectionVariables.set('userRole', body.data.user.role || '');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as Admin (set token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Logs in as Admin and saves JWT to collection variable token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login successful', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "if (body && body.data && body.data.token) {",
                  "  pm.collectionVariables.set('token', body.data.token);",
                  "}",
                  "if (body && body.data && body.data.user) {",
                  "  pm.collectionVariables.set('userId', body.data.user.id || '');",
                  "  pm.collectionVariables.set('userRole', body.data.user.role || '');",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Records APIs",
      "item": [
        {
          "name": "Create Financial Record",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('idempotencyKey', 'record-' + Date.now());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create record success', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const body = pm.response.json();",
                  "if (body && body.data && body.data.record && body.data.record.id) {",
                  "  pm.collectionVariables.set('recordId', body.data.record.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{idempotencyKey}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1245.75,\n  \"type\": \"expense\",\n  \"category\": \"Rent\",\n  \"date\": \"2026-04-01T00:00:00.000Z\",\n  \"note\": \"April apartment rent\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/records",
            "description": "Creates a financial record. Requires Analyst or Admin role and Idempotency-Key header."
          }
        },
        {
          "name": "List Financial Records",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/records?page=1&limit=20&type=expense",
            "description": "Lists records with pagination and filters."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('List records success', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "if (body && body.data && Array.isArray(body.data.data) && body.data.data.length > 0) {",
                  "  pm.collectionVariables.set('recordId', body.data.data[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Financial Record By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/records/{{recordId}}",
            "description": "Fetches one financial record by id."
          }
        },
        {
          "name": "Update Financial Record",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1199.5,\n  \"note\": \"Updated from Postman collection\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/records/{{recordId}}",
            "description": "Updates an existing financial record. Requires Analyst or Admin role."
          }
        },
        {
          "name": "Delete Financial Record (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/records/{{recordId}}",
            "description": "Soft-deletes a record. Admin role required. Run Login as Admin first."
          }
        }
      ]
    },
    {
      "name": "Stats APIs",
      "item": [
        {
          "name": "Get Summary Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/stats/summary",
            "description": "Returns summary totals for income, expense, and balance."
          }
        },
        {
          "name": "Get Category Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/stats/category",
            "description": "Returns totals grouped by category and type."
          }
        },
        {
          "name": "Get Monthly Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/stats/monthly",
            "description": "Returns monthly aggregated trends."
          }
        }
      ]
    }
  ],
